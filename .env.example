# Supabase (Project Settings → Database → Connection string → "Shared Pooler")
# Le host direct (db.<ref>.supabase.co) est en IPv6 seul et échoue souvent (erreur Prisma P1001) —
# utiliser le pooler (aws-0-<region>.pooler.supabase.com) pour les deux variables.
# DATABASE_URL : pooler en mode "Transaction" (port 6543, pgbouncer=true) — utilisée à l'exécution.
# DIRECT_URL   : pooler en mode "Session" (port 5432) — nécessaire pour `prisma migrate`.
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-xxxx.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:password@aws-0-xxxx.pooler.supabase.com:5432/postgres"

# Supabase Auth (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
# Clé "anon" / "publishable" (sb_publishable_... ou legacy eyJ...) — safe côté client.
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
# Clé "secret" / "service_role" (sb_secret_... ou legacy eyJ...) — JAMAIS NEXT_PUBLIC_, jamais côté client.
SUPABASE_SECRET_KEY="sb_secret_..."
